# Vaultship server (docker-compose)
# Copy to .env and adjust. Do not commit .env.

# Port the server listens on (host and container)
PORT=8090

# Optional: absolute DB path inside the container.
# Keep the default unless you know you need a custom location.
DB_PATH=/data/vaultship.db

# API key used by the server for auth.
# Set this explicitly for deterministic deployments.
# If unset, the container generates one once and stores it in /data/api-key.
VAULTSHIP_API_KEY=change-me

# Optional: print API key to container logs on startup (true/false)
PRINT_API_KEY=true

# GitHub token used by the server for auth.
# Set this explicitly for deterministic deployments.
# If unset, the container generates one once and stores it in /data/github-token.
GITHUB_TOKEN=change-me