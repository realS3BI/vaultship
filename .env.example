# PocketBase server (docker-compose)
# Copy to .env and adjust. Do not commit .env.

# Port the server listens on (host and container)
PORT=8090

# Admin user: created/updated on every startup when both are set
# After first start, log in at http://localhost:PORT (or your PB_URL), create an API token, then: vaultship config set apiKey <token>
PB_ADMIN_EMAIL=admin@example.com
PB_ADMIN_PASSWORD=change-me

# Optional: base URL where you reach PocketBase (for your own reference; vaultship uses apiUrl from vaultship config)
# PB_URL=http://localhost:8090
