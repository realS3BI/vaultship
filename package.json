{
  "name": "vaultship",
  "version": "1.1.17",
  "description": "Release automation and encrypted environment synchronization for GitHub projects.",
  "repository": {
    "type": "git",
    "url": "https://github.com/realS3BI/vaultship"
  },
  "type": "module",
  "bin": {
    "vaultship": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "src/templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "generate-api-key": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "prepublishOnly": "pnpm build",
    "prepare": "husky",
    "release": "pnpm build && node dist/cli/index.js release",
    "release:minor": "pnpm build && node dist/cli/index.js release --minor",
    "release:major": "pnpm build && node dist/cli/index.js release --major",
    "env:push": "npx vaultship env push",
    "env:pull": "npx vaultship env pull"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^14.0.3",
    "conventional-changelog": "^7.2.0",
    "glob": "^13.0.6",
    "octokit": "^5.0.5",
    "ora": "^9.3.0",
    "prompts": "^2.4.2",
    "uuid": "^13.0.0",
    "yaml": "^2.6.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.6.0",
    "husky": "^9.1.7",
    "@types/node": "^25.3.3",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.6",
    "typescript": "^5.7.3",
    "vaultship": "1.1.11"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.5.2"
}
